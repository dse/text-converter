{
    // Restricting Options
    "bitwise":          true,
    "curly":            true,
    "eqeqeq":           true,
    "esversion":        11,             // 6 = 2015; ...; 11 = 2020
    "forin":            true,
    "freeze":           true,
    "futurehostile":    true,
    "globals":          {},
    "latedef":          "nofunc",       // "nofunc" allows function hosting
    "leanswitch":       true,
    // "maxcomplexity": 0,
    // "maxdepth":      0,
    // "maxerr":        0,
    // "maxlen":        0,
    // "maxparams":     0,
    // "maxstatements": 0,
    "noarg":            true,
    "nocomma":          true,
    "nonbsp":           true,
    "nonew":            true,
    "noreturnawait":    true,
    "predef":           [],
    "regexpu":          false,
    "shadow":           "outer",
    "singleGroups":     false,
    "strict":           "implied",      // "implied" for modules; i use "global" for cjs code
    "trailingcomma":    false,
    "undef":            true,
    "unused":           true,
    "varstmt":          true,

    // Relaxing Options
    "asi":              false,
    "boss":             false,
    "debug":            false,
    "elision":          false,
    "eqnull":           true,
    "evil":             false,
    "expr":             false,
    "funcscope":        false,
    "iterator":         false,
    "lastsemic":        false,
    "loopfunc":         false,
    "moz":              false,
    "notypeof":         false,
    "noyield":          false,
    "plusplus":         false,
    "proto":            false,
    "scripturl":        false,
    "supernew":         false,
    "validthis":        false,
    "withstmt":         false,

    // Environments
    "browser":          true,          // see also devel
    "browserify":       false,
    "couch":            false,
    "devel":            true,
    "dojo":             false,
    "jasmine":          false,
    "jquery":           false,
    "mocha":            false,
    "module":           true,
    "mootools":         false,
    "node":             false,
    "nonstandard":      false,
    "phantom":          false,
    "prototypejs":      false,
    "qunit":            false,
    "rhino":            false,
    "shelljs":          false,
    "typed":            false,
    "worker":           false,
    "wsh":              false,
    "yui":              false
}
